*.ckpt

# HuggingFace cache
.cache/
.huggingface/

# Weights & Biases
wandb/

# LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.toc
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz
# Note: paper/main.pdf is intentionally NOT ignored — commit the compiled PDF
# alongside the source so readers without a LaTeX toolchain can read the paper.

# OS
.DS_Store
Thumbs.db

# Secrets / environment
.env
.env.*
!.env.example
